# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# SOLO server-side. Cliente admin: invite de usuarios + app_metadata (tenant_id, role). Nunca al browser.
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_PROJECT_REF=<project-ref>

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── IA · extracción de documentos (Claude) ───
ANTHROPIC_API_KEY=

# ─── WhatsApp Worker (Baileys) ───
WHATSAPP_WORKER_WEBHOOK_SECRET=

# ─── Meta WhatsApp Cloud API (webhook /api/webhooks/meta) ───
META_VERIFY_TOKEN=
META_APP_SECRET=
# (el phone_number_id y graph_token van por canal en channels.config, no acá)

# ─── Ingesta de leads Facebook/Google (/api/webhooks/leads) ───
LEADS_INGEST_SECRET=
